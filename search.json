---
layout: null
---
[
  {% for page in site.html_pages %}
    {
      "title": {{ page.title | default: page.name | jsonify }},
      "url": {{ page.url | relative_url | jsonify }},
      "content": {{ page.content | strip_html | strip_newlines | truncate: 5000 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
